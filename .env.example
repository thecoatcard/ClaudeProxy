# ============================================================
# REQUIRED — copy this file to .env and fill in real values.
# NEVER commit .env to source control (.gitignore covers it).
# ============================================================

# Gateway authentication key (set in Claude Code's API key field)
MASTER_API_KEY=your-secret-gateway-key-here

# Upstash Redis (for API key pool management and caching)
REDIS_URL=https://your-redis-instance.upstash.io
REDIS_TOKEN=your-upstash-redis-token-here

# Default and fallback Gemini models
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
FALLBACK_MODEL=gemini-2.5-flash

# Admin dashboard credentials
CRON_SECRET=your-cron-secret-here
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-password-here

# ============================================================
# OPTIONAL — tune behaviour (defaults shown)
# ============================================================

# Enable swarm mode (parallel key probing)
SWARM_MODE=true

# API key cooldown windows (seconds)
KEY_COOLDOWN_429=60
KEY_COOLDOWN_503=10

# Retry configuration
MAX_RETRIES=10
OVERLOAD_FAST_FAIL_AFTER=3

# Request timeout (ms)
REQUEST_TIMEOUT=180000

# Compaction settings
COMPACTION_CHUNK_TIMEOUT_MS=20000
COMPACTION_TOOL_OUTPUT_MAX_CHARS=4000
CONTEXT_SUMMARY_TTL=21600

# Tool output archive settings
TOOL_ARCHIVE_THRESHOLD=3000
TOOL_ARCHIVE_KEEP_RECENT=2
TOOL_ARCHIVE_TTL=1800
